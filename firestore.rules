rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function hasAnyRole(roles) {
      return request.auth != null && request.auth.token.roles.hasAny(roles);
    }

    // Allow admins to read and write all documents
    match /{document=**} {
      allow read, write: if hasAnyRole(["ADMIN", "OWNER"]);
    }

    // Schools: Allow public to read all documents, anyone can write
    match /schools/{document=**} {
      allow read: if true;
      allow write: if true;
    }

    // Students: Allow public to read all documents, only authenticated users can write
    match /students/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config + item banks: no direct client access for normal users (API uses Admin SDK).
    // ADMIN / OWNER still covered by the catch-all rule above.
    match /app_config/{document=**} {
      allow read, write: if hasAnyRole(["ADMIN", "OWNER"]);
    }

    match /assessment_types/{document=**} {
      allow read, write: if hasAnyRole(["ADMIN", "OWNER"]);
    }

    match /institution_demo_requests/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Proctoring analytics: assumes doc id is the student's Firebase uid. Change if your schema differs.
    match /student_proctoring_confidence/{studentUid} {
      allow read, update, delete: if request.auth != null && request.auth.uid == studentUid;
      allow create: if request.auth != null && request.auth.uid == studentUid;
    }
  }
}
